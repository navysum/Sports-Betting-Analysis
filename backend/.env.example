# football-data.org — free tier, sign up at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_key_here

# RapidAPI key — ONE key covers all 3 subscriptions:
#   • Sofascore (Api Dojo)             → real xG data for predictions
#   • Free API Live Football Data      → 2100+ leagues, live scores
#   • SportAPI (rapidsportapi)         → fast backup fixtures (141 ms)
# https://rapidapi.com/developer/apps → copy "X-RapidAPI-Key"
RAPIDAPI_KEY=your_rapidapi_key_here

# API-Football via RapidAPI (legacy) — free 100 req/day
# If you only have one RapidAPI key, set API_FOOTBALL_KEY to the same value as RAPIDAPI_KEY
API_FOOTBALL_KEY=your_rapidapi_key_here

# The Odds API — free 500 req/month, https://the-odds-api.com (enables live value bet detection)
ODDS_API_KEY=your_odds_api_key_here

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Telegram group / chat to send alerts to (Jarvis HQ)
TELEGRAM_CHAT_ID=-5002959525

# Your personal Telegram user ID (for admin commands)
TELEGRAM_USER_ID=5757363641

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./data/soccerbet.db

# Directories (relative to backend/)
DATA_DIR=./data
MODELS_DIR=./ml
CSV_DIR=./data/csv

# Timezone for scheduling
TIMEZONE=Europe/London
